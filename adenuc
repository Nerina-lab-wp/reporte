<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Estado de Participantes</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<style>
body {
  font-family: 'Inter', system-ui, sans-serif;
  background: #f7f9fb;
  padding: 24px;
  color: #1f2937;
}

/* TITLE */
h1 {
  font-size: 22px;
  margin-bottom: 20px;
}

/* SUMMARY */
.summary {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
  margin-bottom: 24px;
}

.card {
  background: white;
  border-radius: 14px;
  padding: 16px;
  text-align: center;
  box-shadow: 0 6px 18px rgba(0,0,0,0.05);
  transition: 0.2s;
}

.card:hover {
  transform: translateY(-3px);
}

.card-title {
  font-size: 12px;
  color: #6b7280;
}

.card-value {
  font-size: 30px;
  font-weight: 600;
  margin: 6px 0;
}

.card-sub {
  font-size: 11px;
  color: #9ca3af;
}

/* FILTERS */
.filters {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 16px;
}

.filters button {
  font-size: 12px;
  padding: 6px 14px;
  border-radius: 999px;
  border: none;
  background: #eef2f7;
  cursor: pointer;
  transition: 0.2s;
}

.filters button:hover {
  background: #e2e8f0;
}

/* TABLE */
.table-container {
  background: white;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 8px 24px rgba(0,0,0,0.05);
}

table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}

thead {
  background: #f1f5f9;
}

th {
  text-align: left;
  padding: 12px;
  font-weight: 500;
  color: #6b7280;
}

td {
  padding: 10px 12px;
}

tr {
  border-top: 1px solid #f1f5f9;
  transition: 0.15s;
}

tr:hover {
  background: #f9fbfd;
}

.badge {
  font-size: 11px;
  padding: 4px 8px;
  border-radius: 10px;
  display: inline-block;
}

/* COLORS */
.green { background:#E1F5EE; color:#085041; }
.red { background:#FCEBEB; color:#501313; }
.yellow { background:#FAEEDA; color:#412402; }
.orange { background:#FAECE7; color:#4A1B0C; }
</style>
</head>

<body>

<h1>Estado de Participantes</h1>

<div class="summary">
  <div class="card">
    <div class="card-title">Completaron</div>
    <div class="card-value" style="color:#0F6E56;">37</div>
    <div class="card-sub">69%</div>
  </div>

  <div class="card">
    <div class="card-title">No cursaron</div>
    <div class="card-value" style="color:#A32D2D;">8</div>
    <div class="card-sub">15%</div>
  </div>

  <div class="card">
    <div class="card-title">En curso</div>
    <div class="card-value" style="color:#BA7517;">7</div>
    <div class="card-sub">13%</div>
  </div>

  <div class="card">
    <div class="card-title">Bajo rendimiento</div>
    <div class="card-value" style="color:#E24B4A;">2</div>
    <div class="card-sub">&lt;70</div>
  </div>
</div>

<div class="filters">
  <button onclick="filter('todos')">Todos (54)</button>
  <button onclick="filter('Completó')">Completaron</button>
  <button onclick="filter('No cursó')">No cursaron</button>
  <button onclick="filter('En curso / incompleto')">En curso</button>
  <button onclick="filter('Bajo rendimiento')">Bajo rendimiento</button>
</div>

<div class="table-container">
<table>
<thead>
<tr>
<th>Nombre</th>
<th>Email</th>
<th style="text-align:center;">Promedio</th>
<th style="text-align:center;">Estado</th>
</tr>
</thead>
<tbody id="tableBody"></tbody>
</table>
</div>

<script>
const data = [
  ["Alexis Cuartas","alexis.cuartas@adenuniversity.edu.pa",100,"En curso / incompleto"],
  ["PAOLA PINILLA","andrea.pinilla@adenuniversity.edu.pa",null,"En curso / incompleto"],
  ["Jhonatan Betancourt","jhonatan.betancourt@adenuniversity.edu.pa",null,"No cursó"],
  ["Daniel Villada","daniel.villada@adenuniversity.edu.pa",95,"Completó"],
  ["Edwin Ortiz","edwin.ortiz@adenuniversity.edu.pa",null,"No cursó"],
  ["Liliana Mercado","liliana.mercado@adenuniversity.edu.pa",null,"No cursó"],
  ["Jensy Mena","jensy.mena@adenuniversity.edu.pa",100,"Completó"],
  ["Ana Taborda","ana.taborda@adenuniversity.edu.pa",97.5,"Completó"],
  ["Alejandro Arroyave","alejandro.arroyave@adenuniversity.edu.pa",97.5,"Completó"],
  ["Luis Eduardo Florez Ricardo","luis.florez@adenuniversity.edu.pa",85.75,"Completó"],
  ["Jeison Cordero","jeison.cordero@adenuniversity.edu.pa",65.75,"Bajo rendimiento"],
  ["Jennifer Mosquera","jennifer.mosquera@adenuniversity.edu.pa",66.25,"Bajo rendimiento"]
];

let current = 'todos';

function filter(f) {
  current = f;
  render();
}

function getBadge(status) {
  if (status === "Completó") return "badge green";
  if (status === "No cursó") return "badge red";
  if (status === "En curso / incompleto") return "badge yellow";
  return "badge orange";
}

function render() {
  const body = document.getElementById('tableBody');
  const filtered = current === 'todos' ? data : data.filter(r => r[3] === current);

  body.innerHTML = filtered.map(r => {
    const prom = r[2] !== null ? r[2].toFixed(1) : '—';
    const color = r[2] === null ? '#9ca3af' : r[2] >= 90 ? '#0F6E56' : r[2] >= 70 ? '#1f2937' : '#A32D2D';

    return `
    <tr>
      <td>${r[0]}</td>
      <td style="color:#6b7280;font-size:12px;">${r[1]}</td>
      <td style="text-align:center;font-weight:500;color:${color};">${prom}</td>
      <td style="text-align:center;">
        <span class="${getBadge(r[3])}">${r[3]}</span>
      </td>
    </tr>`;
  }).join('');
}

render();
</script>

</body>
</html>
